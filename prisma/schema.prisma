generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  superAdmin
  admin
  client
  deliveryDriver
}

enum OrderStatus {
  pendiente
  pagoConfirmado
  preparando
  listaParaReparto
  enReparto
  entregada
  cancelada
}

model User {
  id        String   @id @default(uuid())
  address   String?
  createdAt DateTime @default(now())
  email     String   @unique
  firstName String
  lastName  String
  numberId  String   @unique
  password  String
  phone     String?
  type      UserType
  updatedAt DateTime @updatedAt

  linkedDevices       LinkedDevice[]
  notifications       Notification[]
  orders              Order[]
  deliveryAssignments Order[]              @relation("OrderDeliveryUser")
  passwordResetTokens PasswordResetToken[]
  tokens              Token[]
}

model Product {
  id               String   @id @default(uuid())
  active           Boolean  @default(true)
  code             String   @unique
  cost             Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  department       String
  description      String?
  imageUrl         String?
  brand            String
  name             String
  price            Decimal  @db.Decimal(12, 2)
  updatedAt        DateTime @updatedAt
  initialBalance   Int?
  adminMovements   Int?
  salesToday       Int?
  totalStock       Int?
  inventoryValueBs Decimal? @db.Decimal(14, 2)
  marginPct        Decimal? @db.Decimal(10, 2)

  @@index([active])
  @@index([name, brand, code])
  @@index([description])
  @@index([brand])
}

model Order {
  id               String      @id @default(uuid())
  userId           String
  status           OrderStatus @default(pendiente)
  products         Json        @default("[]")
  totalAmount      Decimal     @db.Decimal(14, 2)
  confirmationCode String?     @unique
  paidAt           DateTime?
  deliveryUserId   String?
  deliveryAddress  String?
  deliveryPhone    String?
  customerNotes    String?
  idempotencyKey   String?     @unique
  version          Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryUser  User?          @relation("OrderDeliveryUser", fields: [deliveryUserId], references: [id])
  notifications Notification[]

  @@index([userId, status])
  @@index([status])
  @@index([deliveryUserId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  payload   Json?
  orderId   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Token {
  id             String   @id @default(uuid())
  createdAt      DateTime
  expirationDate DateTime
  userId         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DateBaseVersion {
  id             String   @id @default(uuid())
  currentVersion Int
  updatedAt      DateTime
}

model LinkedDevice {
  id               String   @id @default(uuid())
  createdAt        DateTime
  deviceId         String
  refreshTokenHash String
  userId           String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}
