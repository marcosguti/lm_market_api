generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  superAdmin
  admin
  client
  deliveryDriver
}

enum NumberIdType {
  V
  E
  P
  J
}

enum OrderStatus {
  pending
  paymentConfirmed
  preparing
  readyForDelivery
  outForDelivery
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  zelle
  mobilePayment
  binance
}

model User {
  id            String       @id @default(uuid())
  address       String?
  createdAt     DateTime     @default(now())
  email         String       @unique
  firstName     String
  lastName      String
  numberId      String       @unique
  numberIdType  NumberIdType
  password      String
  phone         String?      @unique
  phoneVerified Boolean      @default(false)
  emailVerified Boolean      @default(false)
  type          UserType
  updatedAt     DateTime     @updatedAt

  linkedDevices          LinkedDevice[]
  notifications          Notification[]
  orders                 Order[]
  deliveryAssignments    Order[]                 @relation("OrderDeliveryUser")
  passwordResetTokens    PasswordResetToken[]
  emailVerificationCodes EmailVerificationCode[]
  tokens                 Token[]
}

enum OtpCodePurpose {
  email_verification
  login
}

model EmailVerificationCode {
  id             String         @id @default(uuid())
  codeHash       String
  expiresAt      DateTime
  failedAttempts Int            @default(0)
  purpose        OtpCodePurpose @default(email_verification)
  createdAt      DateTime       @default(now())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, purpose])
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([name])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([name])
}

model Product {
  id           String   @id @default(uuid())
  active       Boolean  @default(true)
  brand        String
  brandId      String?
  code         String   @unique
  createdAt    DateTime @default(now())
  department   String
  departmentId String?
  description  String?
  imageUrl     String?
  name         String
  updatedAt    DateTime @updatedAt

  brandRef      Brand?         @relation(fields: [brandId], references: [id])
  departmentRef Department?    @relation(fields: [departmentId], references: [id])
  productStores ProductStore[]

  @@index([active])
  @@index([name, brand, code])
  @@index([description])
  @@index([brand])
  @@index([brandId])
  @@index([departmentId])
}

model Store {
  id                 String   @id @default(uuid())
  name               String   @db.VarChar(100)
  externalBranchCode String   @unique @db.VarChar(50)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  productStores ProductStore[]
  orders        Order[]

  @@index([externalBranchCode])
}

model ProductStore {
  productId     String
  storeId       String
  price         Decimal  @db.Decimal(12, 2)
  stockQuantity Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@id([productId, storeId])
  @@index([storeId])
}

model Order {
  id                   String         @id @default(uuid())
  userId               String
  storeId              String?
  status               OrderStatus    @default(pending)
  products             Json           @default("[]")
  totalAmount          Decimal        @db.Decimal(14, 2)
  confirmationCode     String?        @unique
  paidAt               DateTime?
  deliveryUserId       String?
  deliveryAddress      String?
  deliveryPhone        String?
  customerNotes        String?
  idempotencyKey       String?        @unique
  version              Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  paymentMethod        PaymentMethod?
  paymentReference     String?
  paymentDate          DateTime?
  paymentScreenshotUrl String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryUser  User?          @relation("OrderDeliveryUser", fields: [deliveryUserId], references: [id])
  store         Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  notifications Notification[]
  payment       Payment?

  @@index([userId, status])
  @@index([status])
  @@index([deliveryUserId])
  @@index([storeId])
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String        @unique
  method                PaymentMethod
  reference             String
  paidAt                DateTime
  screenshotUrl         String?
  verifiedAt            DateTime?
  verifiedBy            String?
  gatewayControl        String?
  gatewayStatus         String?
  gatewayVoucher        String?
  gatewayRawResponse    Json?
  verifiedAutomatically Boolean       @default(false)
  payerCid              String?
  payerPhone            String?
  payerBankCode         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  payload   Json?
  orderId   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Token {
  id             String   @id @default(uuid())
  createdAt      DateTime
  expirationDate DateTime
  userId         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DateBaseVersion {
  id             String   @id @default(uuid())
  currentVersion Int
  updatedAt      DateTime
}

model LinkedDevice {
  id               String   @id @default(uuid())
  createdAt        DateTime
  deviceId         String
  refreshTokenHash String
  userId           String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Deal {
  id          String   @id @default(uuid())
  description String?  @db.VarChar(300)
  imageUrl    String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startDate, endDate])
}

model Banner {
  id          String   @id @default(uuid())
  active      Boolean  @default(true)
  imageUrl    String
  description String?  @db.VarChar(300)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}
