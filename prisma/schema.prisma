generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  superAdmin
  admin
  client
  deliveryDriver
}

enum NumberIdType {
  V
  E
  P
  J
}

enum OrderStatus {
  pending
  paymentPendingConfirmation
  paymentConfirmed
  preparing
  readyForDelivery
  assignedToDeliveryDriver
  delivering
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  zelle
  mobilePayment
  binance
}

model User {
  id                String       @id @default(uuid())
  address           String?
  addressCity       String?      @db.VarChar(32)
  addressLatitude   Decimal?     @db.Decimal(10, 7)
  addressLongitude  Decimal?     @db.Decimal(10, 7)
  createdAt         DateTime     @default(now())
  email             String       @unique
  firstName         String
  lastName          String
  numberId          String       @unique
  numberIdType      NumberIdType
  password          String
  phone             String?      @unique
  phoneVerified     Boolean      @default(false)
  emailVerified     Boolean      @default(false)
  storeId           String?
  type              UserType
  updatedAt         DateTime     @updatedAt

  linkedDevices          LinkedDevice[]
  notifications          Notification[]
  orders                 Order[]
  deliveryAssignments    Order[]                 @relation("OrderDeliveryUser")
  orderStatusChanges     OrderStatusHistory[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationCodes EmailVerificationCode[]
  pushDevices            PushDevice[]
  store                  Store?                  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  tokens                 Token[]

  @@index([storeId])
}

enum OtpCodePurpose {
  email_verification
  login
}

model EmailVerificationCode {
  id             String         @id @default(uuid())
  codeHash       String
  expiresAt      DateTime
  failedAttempts Int            @default(0)
  purpose        OtpCodePurpose @default(email_verification)
  createdAt      DateTime       @default(now())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, purpose])
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([name])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([name])
}

model Product {
  id           String   @id @default(uuid())
  active       Boolean  @default(true)
  brand        String
  brandId      String?
  code         String   @unique
  createdAt    DateTime @default(now())
  department   String
  departmentId String?
  description  String?
  imageUrl     String?
  name         String
  updatedAt    DateTime @updatedAt

  brandRef      Brand?         @relation(fields: [brandId], references: [id])
  departmentRef Department?    @relation(fields: [departmentId], references: [id])
  productStores ProductStore[]

  @@index([active])
  @@index([name, brand, code])
  @@index([description])
  @@index([brand])
  @@index([brandId])
  @@index([departmentId])
}

model Store {
  id                 String   @id @default(uuid())
  name               String   @db.VarChar(100)
  externalBranchCode String   @unique @db.VarChar(50)
  active             Boolean  @default(true)
  city               String?  @db.VarChar(32)
  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  admins        User[]
  orders        Order[]
  productStores ProductStore[]

  @@index([externalBranchCode])
  @@index([active])
}

model ProductStore {
  productId     String
  storeId       String
  price         Decimal  @db.Decimal(12, 2)
  stockQuantity Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@id([productId, storeId])
  @@index([storeId])
}

model ExchangeRate {
  id        String   @id @default(uuid())
  pair      String   @unique @db.VarChar(16)
  rate      Decimal  @db.Decimal(14, 8)
  source    String   @db.VarChar(32)
  fetchedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pair])
}

model Order {
  id                   String         @id @default(uuid())
  userId               String
  storeId              String?
  status               OrderStatus    @default(pending)
  products             Json           @default("[]")
  totalAmount          Decimal        @db.Decimal(14, 2)
  exchangeRate         Decimal?       @db.Decimal(14, 8)
  confirmationCode     String?        @unique
  paidAt               DateTime?
  deliveryUserId       String?
  deliveryAddress      String?
  deliveryLatitude     Decimal?       @db.Decimal(10, 7)
  deliveryLongitude    Decimal?       @db.Decimal(10, 7)
  deliveryPhone        String?
  customerNotes        String?
  idempotencyKey       String?        @unique
  version              Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  paymentMethod        PaymentMethod?
  paymentReference     String?
  paymentDate          DateTime?
  paymentScreenshotUrl String?
  deliveryProofUrl     String?
  cancellationReason   String?

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryUser  User?                  @relation("OrderDeliveryUser", fields: [deliveryUserId], references: [id])
  store         Store?                 @relation(fields: [storeId], references: [id], onDelete: SetNull)
  notifications Notification[]
  payment       Payment?
  statusHistory OrderStatusHistory[]
  tracking      OrderDeliveryTracking?

  @@index([userId, status])
  @@index([status])
  @@index([deliveryUserId])
  @@index([storeId])
}

model OrderDeliveryTracking {
  orderId           String   @id
  latitude          Decimal  @db.Decimal(10, 7)
  longitude         Decimal  @db.Decimal(10, 7)
  accuracyMeters    Float?
  headingDegrees    Float?
  speedMps           Float?
  deviceRecordedAt   DateTime?
  serverReceivedAt  DateTime @default(now())
  trackingSessionId String?
  deviceId          String?
  routeGeometry     Json?
  distanceMeters    Float?
  etaSeconds         Int?
  routeCalculatedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([serverReceivedAt])
}

model OrderStatusHistory {
  id              String      @id @default(uuid())
  orderId         String
  fromStatus      OrderStatus
  toStatus        OrderStatus
  changedByUserId String
  createdAt       DateTime    @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User  @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
  @@index([changedByUserId])
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String        @unique
  method                PaymentMethod
  note                  String?       @db.VarChar(100)
  reference             String
  paidAt                DateTime
  screenshotUrl         String?
  verifiedAt            DateTime?
  verifiedBy            String?
  gatewayControl        String?
  gatewayStatus         String?
  gatewayVoucher        String?
  gatewayRawResponse    Json?
  verifiedAutomatically Boolean       @default(false)
  payerCid              String?
  payerPhone            String?
  payerBankCode         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PaymentMethodConfig {
  method      PaymentMethod @id
  active      Boolean       @default(true)
  information String?       @db.Text
  placeholder String?       @db.VarChar(200)
  noteEnabled Boolean       @default(false)
  updatedAt   DateTime      @updatedAt
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  payload   Json?
  orderId   String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Token {
  id             String   @id @default(uuid())
  createdAt      DateTime
  expirationDate DateTime
  userId         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DateBaseVersion {
  id             String   @id @default(uuid())
  currentVersion Int
  updatedAt      DateTime
}

model LinkedDevice {
  id               String   @id @default(uuid())
  createdAt        DateTime
  deviceId         String
  refreshTokenHash String
  userId           String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

model PushDevice {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  platform  String
  token     String   @unique
  updatedAt DateTime @updatedAt
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Deal {
  id          String   @id @default(uuid())
  active      Boolean  @default(true)
  description String?  @db.VarChar(300)
  imageUrl    String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([startDate, endDate])
}

model Banner {
  id          String   @id @default(uuid())
  active      Boolean  @default(true)
  imageUrl    String
  description String?  @db.VarChar(300)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model BlogArticle {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(200)
  content   String   @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt])
}
