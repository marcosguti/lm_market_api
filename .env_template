POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lm_market
POSTGRES_PORT=5434
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}"
PORT=3000
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-in-production
EXTERNAL_PRODUCTS_BASE_URL=https://lmmarket.leandatech.com/api/productos/full-search
EXTERNAL_PRODUCTS_API_KEY=
DIGITAL_OCEAN_BUCKET=
DIGITAL_OCEAN_URL=https://lm-market-images.atl1.cdn.digitaloceanspaces.com/
DIGITAL_OCEAN_SPACES_ENDPOINT=
DIGITAL_OCEAN_SPACES_KEY=
DIGITAL_OCEAN_SPACES_SECRET=

# Tasa USD → Bs para Pago Móvil Megasoft (validación server-side del monto enviado por el front)
USD_PRICE=600

# Megasoft P2C — sandbox (https://paytest.megasoft.com.ve/payment)
MEGASOFT_ENABLED=false
MEGASOFT_BASE_URL=https://paytest.megasoft.com.ve/payment
MEGASOFT_USER=lmmarket
MEGASOFT_PASSWORD=Caracas123.1
MEGASOFT_AFFILIATION_CODE=20260629
MEGASOFT_MERCHANT_PHONE=04121234567
MEGASOFT_MERCHANT_CID=Integrador
MEGASOFT_MERCHANT_BANK_CODE=0138
MEGASOFT_MERCHANT_RIF=
MEGASOFT_MERCHANT_BANK_NAME=Banco Plaza
MEGASOFT_PAYMENT_TYPE=10
MEGASOFT_SUPPORTED_BANK_CODES=0134,0102,0105,0108,0138,0171,0172,0174,0169
MEGASOFT_TLS_INSECURE=true
MEGASOFT_SIMULATE_PLATFORM_DOWN=false
MEGASOFT_DEBUG_LOGS=true
# Certificación: payload fijo del ejemplo Megasoft (36000.00, 04125555444, 0105, etc.)
MEGASOFT_CERT_HARDCODED=false
# Solo si MEGASOFT_CERT_HARDCODED=false: fuerza el monto enviado a Megasoft
MEGASOFT_AMOUNT_OVERRIDE=
